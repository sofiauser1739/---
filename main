<script>
    // ---------- МОДЕЛЬ ДАННЫХ ----------
    let gameState = {
        balance: 100,
        level: 1,
        passivePerHour: 0,
        passedQuizzes: new Set(), // какие уровни пройдены
        lastTapTime: 0,
        comboActive: false,
        ownedCards: [], // id купленных карт
        cardDebuffs: {} // id карты -> до какого времени (timestamp) ослаблена
    };

    // Доступные инвестиции
    const cardsCatalog = [
        { id: 'piggy', title: 'Копилка', desc: 'надёжно, как банка', price: 80, incomeBoost: 45, risk: 0 },
        { id: 'crypto', title: 'Криптобобр', desc: 'высокий доход, но волатильный', price: 450, incomeBoost: 280, risk: 0.35 },
        { id: 'stocks', title: 'Акции Грызунпрома', desc: 'стабильный дивиденд', price: 1200, incomeBoost: 560, risk: 0.1 }
    ];

    // Викторины
    const quizzes = [
        { levelReq: 1, question: "Что лучше всего помогает не прогореть?", options: ["Держать всё в одной крипте", "Диверсификация", "Спрятать под подушку"], correct: 1, reward: 50 },
        { levelReq: 2, question: "Что такое пассивный доход?", options: ["Фриланс", "Деньги, которые работают без тебя", "Лотерейный билет"], correct: 1, reward: 80 },
        { levelReq: 3, question: "Какой актив самый рискованный?", options: ["Криптовалюта", "Депозит в банке", "Облигации"], correct: 0, reward: 120 }
    ];

// Вспомогательные функции
    function formatBalance(b) { return b.toFixed(2); }
    function updateUI() {
        document.getElementById('balanceDisplay').innerText = formatBalance(gameState.balance);
        document.getElementById('levelDisplay').innerText = gameState.level;
        // пересчёт активного пассивного дохода (учитывая дебаффы)
        let totalIncome = 0;
        for (let card of cardsCatalog) {
            if (gameState.ownedCards.includes(card.id)) {
                const debuffUntil = gameState.cardDebuffs[card.id];
                const isDebuffed = debuffUntil && Date.now() < debuffUntil;
                if (!isDebuffed) totalIncome += card.incomeBoost;
            }
        }
        gameState.passivePerHour = totalIncome;
        document.getElementById('incomePerHour').innerText = Math.floor(totalIncome) + " ₿";
        
        renderShop();
        renderAcademy();
    }

    // пассивный доход тикает каждую секунду
    function startPassiveIncome() {
        setInterval(() => {
            if (gameState.passivePerHour > 0) {
                let incomePerSec = gameState.passivePerHour / 3600;
                gameState.balance += incomePerSec;
                checkLevelUp();
                updateUI();
            }
        }, 1000);
    }

    // клик по Бизику
    function onTapGuinea() {
        const now = Date.now();
        let reward = 1 + (gameState.level - 1) * 0.2;
        if (gameState.lastTapTime && (now - gameState.lastTapTime) < 500) {
            reward *= 2;
            gameState.comboActive = true;
            document.getElementById('comboLabel').innerHTML = "✨ КОМБО x2 ✨";
            setTimeout(() => {
                if(document.getElementById('comboLabel')) document.getElementById('comboLabel').innerHTML = "🐹 кликай!";
            }, 400);
        } else {
            gameState.comboActive = false;
            document.getElementById('comboLabel').innerHTML = "⚡ быстрый клик = комбо";
        }
        gameState.lastTapTime = now;
        gameState.balance += reward;
        checkLevelUp();
        updateUI();
        
        // анимация морской свинки
        const emojiSpan = document.getElementById('guineaEmoji');
        emojiSpan.style.transform = 'scale(0.9)';
        setTimeout(() => { if(emojiSpan) emojiSpan.style.transform = ''; }, 100);
    }

    // покупка карточки
    function buyCard(card) {
        if (gameState.balance >= card.price && !gameState.ownedCards.includes(card.id)) {
            gameState.balance -= card.price;
            gameState.ownedCards.push(card.id);
            // если у карты есть риск - она пока не дебаффнута
            if (card.risk > 0) {
                // риск-менеджер: через случайный интервал может обвалиться
                scheduleRiskForCard(card);
            }
            checkLevelUp();
            updateUI();
            return true;
        }
        return false;
    }

    // риск: временно отключаем бонус карты
    function scheduleRiskForCard(card) {
        // не детерминированно, но правдоподобно: каждые 45-90 сек может триггернуть
        function applyRisk() {
            if (!gameState.ownedCards.includes(card.id)) return;
            const isAlreadyDebuffed = gameState.cardDebuffs[card.id] && gameState.cardDebuffs[card.id] > Date.now();
            if (!isAlreadyDebuffed && Math.random() < 0.25) { // 25% шанс обвала в момент проверки
                gameState.cardDebuffs[card.id] = Date.now() + 15_000; // 15 секунд демо-дебафф (в real игре 15 мин)
                updateUI();
                // через 15 сек снять дебафф
                setTimeout(() => {
                    if (gameState.cardDebuffs[card.id] && gameState.cardDebuffs[card.id] <= Date.now() + 100) {
                        delete gameState.cardDebuffs[card.id];
                        updateUI();
                    }
                }, 15000);
            }
            setTimeout(applyRisk, 30000 + Math.random() * 30000);
        }
        setTimeout(applyRisk, 20000);
    }

function checkLevelUp() {
        let neededBalance = 500 * gameState.level;
        if (gameState.balance >= neededBalance && (gameState.passedQuizzes.has(gameState.level + 1) || gameState.level >= 4)) {
            // если следующий уровень уже сдан или это не требуется для перехода, то повышаем
            if (gameState.passedQuizzes.has(gameState.level + 1) || gameState.level >= 3) {
                gameState.level++;
                updateUI();
            }
        }
    }

    // ответ на викторину
    function answerQuiz(quiz, answerIndex) {
        if (quiz.levelReq > gameState.level) return false;
        if (gameState.passedQuizzes.has(quiz.levelReq)) return false;
        if (answerIndex === quiz.correct) {
            gameState.balance += quiz.reward;
            gameState.passedQuizzes.add(quiz.levelReq);
            checkLevelUp();
            updateUI();
            return true;
        }
        return false;
    }

    // ----- ОТРИСОВКА МАГАЗИНА -----
    function renderShop() {
        const container = document.getElementById('shopPanel');
        if (!container) return;
        let html = '';
        for (let card of cardsCatalog) {
            const owned = gameState.ownedCards.includes(card.id);
            const debuffUntil = gameState.cardDebuffs[card.id];
            const isDebuffed = debuffUntil && debuffUntil > Date.now();
            let riskTag = card.risk > 0 ? <span style="color:#c97e2a;"> ⚠️ риск ${(card.risk*100).toFixed(0)}%</span> : '';
            let debuffTag = isDebuffed ? <div style="color:#b5651e; font-size:12px;">🔻 обвал рынка (бонус отключен)</div> : '';
            html += 
                <div class="card-item ${owned ? 'disabled-card' : ''}">
                    <div class="card-title">${card.title} ${riskTag}</div>
                    <div class="card-desc">${card.desc}</div>
                    <div class="card-stats">
                        <span>➕ +${card.incomeBoost} ₿/час</span>
                        ${!owned ? <button class="buy-btn" data-id="${card.id}">💰 ${card.price} ₿</button> : '<span style="background:#cbdbb8; padding:6px 16px; border-radius:40px;">✅ куплено</span>'}
                    </div>
                    ${debuffTag}
                </div>
            ;
        }
        container.innerHTML = html;
        // навесить события на кнопки
        for (let card of cardsCatalog) {
            const btn = container.querySelector(.buy-btn[data-id="${card.id}"]);
            if (btn) {
                btn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    buyCard(card);
                });
            }
        }
    }

    function renderAcademy() {
        const container = document.getElementById('academyPanel');
        if (!container) return;
        const availableQuizzes = quizzes.filter(q => q.levelReq <= gameState.level && !gameState.passedQuizzes.has(q.levelReq));
        if (availableQuizzes.length === 0) {
            container.innerHTML = <div style="text-align:center; padding:20px;">✅ Все доступные викторины пройдены! Повышай уровень дальше.</div>;
            return;
        }
        let html = <div style="font-weight:bold; margin-bottom:12px;">📚 Ответь на вопрос, чтобы открыть следующий уровень:</div>;
        for (let q of availableQuizzes) {
            html += <div style="background:#ecf0e5; border-radius:28px; padding:12px; margin-bottom:16px;">
                        <div style="font-weight:bold;">⭐ уровень ${q.levelReq} · награда ${q.reward} ₿</div>
                        <div style="margin:8px 0;">❓ ${q.question}</div>;
            for (let i = 0; i < q.options.length; i++) {
                html += <div class="quiz-option" data-qidx="${quizzes.indexOf(q)}" data-optidx="${i}">${q.options[i]}</div>;

}
            html += </div>;
        }
        container.innerHTML = html;
        for (let q of availableQuizzes) {
            const qIndex = quizzes.indexOf(q);
            const opts = container.querySelectorAll(.quiz-option[data-qidx="${qIndex}"]);
            opts.forEach(opt => {
                opt.addEventListener('click', (e) => {
                    const optIndex = parseInt(opt.getAttribute('data-optidx'));
                    const success = answerQuiz(q, optIndex);
                    alert(success ? ✅ Верно! +${q.reward} ₿ : ❌ Неправильно, попробуй ещё раз);
                    renderAcademy();
                    updateUI();
                });
            });
        }
    }

    // --- Переключение табов ---
    function initTabs() {
        const btns = document.querySelectorAll('.tab-btn');
        const shopPanel = document.getElementById('shopPanel');
        const academyPanel = document.getElementById('academyPanel');
        btns.forEach(btn => {
            btn.addEventListener('click', () => {
                btns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                const tab = btn.getAttribute('data-tab');
                if (tab === 'shop') {
                    shopPanel.style.display = 'block';
                    academyPanel.style.display = 'none';
                    renderShop();
                } else {
                    shopPanel.style.display = 'none';
                    academyPanel.style.display = 'block';
                    renderAcademy();
                }
            });
        });
    }

    // приветствие Бизика
    function showWelcome() {
        setTimeout(() => {
            alert("🐹 Привет, я Бизик! Тыкай на меня — зарабатывай. Покупай карточки — доход капает сам. Рискни с криптой, но не прогори. Проходи тесты — качаем уровень! Погнали?");
        }, 200);
    }

    // --- ЗАПУСК ---
    function startGame() {
        initTabs();
        document.getElementById('tapZone').addEventListener('click', onTapGuinea);
        startPassiveIncome();
        updateUI();
        showWelcome();
    }

    startGame();
</script>await callback.answer("Куплено! Теперь доход капает сам.")
    elif callback.data == "buy_card2" and user["balance"] >= 500:
        user["balance"] -= 500
        user["passive_income"] += 10
        await callback.answer("Ого! Ты крипто-инвестор.")
    else:
        await callback.answer("Недостаточно монет!")

# Профиль и уровни
@dp.message(F.text == "🎓 Профиль/Уровни")
async def profile(message: types.Message):
    user = get_user_data(message.from_user.id)
    status = "Новичок (в худи)" if user["level"] == 1 else "Специалист (в костюме)"
    
    text = (
        f"👤 Твой статус: {status}\n"
        f"💰 Баланс: {int(user['balance'])}\n"
        f"⚙️ Пассивный доход: {user['passive_income']} 🪙/сек\n\n"
    )
    
    if not user["quiz_passed"] and user["balance"] >= 100:
        builder = InlineKeyboardBuilder()
        builder.button(text="Пройти тест на 2 уровень", callback_data="start_quiz")
        await message.answer(text + "Тебе доступен новый уровень!", reply_markup=builder.as_markup())
    else:
        await message.answer(text)

# Викторина (Финграмотность)
@dp.callback_query(F.data == "start_quiz")
async def start_quiz(callback: types.CallbackQuery):
    builder = InlineKeyboardBuilder()
    builder.button(text="Игнорировать и заблокировать", callback_data="quiz_right")
    builder.button(text="Сказать код (это же из банка!)", callback_data="quiz_wrong")
    
    await callback.message.edit_text(
        "ВОПРОС: Тебе пишет 'сотрудник банка' и просит код из СМС, чтобы спасти твои деньги. Твои действия?",
        reply_markup=builder.as_markup()
    )

@dp.callback_query(F.data.startswith("quiz_"))

async def quiz_res(callback: types.CallbackQuery):
    user = get_user_data(callback.from_user.id)
    if callback.data == "quiz_right":
        user["level"] = 2
        user["quiz_passed"] = True
        user["click_power"] += 5
        await callback.message.edit_text("Верно! Ты защитил свои деньги и получил 2 уровень (новый костюм и +5 к клику)!")
    else:
        await callback.message.edit_text("Ошибка! Мошенники украли бы твои деньги. Попробуй позже.")

async def main():
    await dp.start_polling(bot)

if name == "main":
    asyncio.run(main())
