et balance = 0;
let clickPower = 1;
let passiveIncome = 0;
let lastUpdate = Date.now();

const balanceDisplay = document.getElementById('balance');
const clickButton = document.getElementById('clickButton');
const passiveIncomeDisplay = document.getElementById('passiveIncome');

// Функция для обновления отображения
function updateDisplay() {
    balanceDisplay.textContent = Balance: ${balance};
    passiveIncomeDisplay.textContent = Passive Income: ${passiveIncome}/sec;
}

// Обработчик клика
clickButton.addEventListener('click', () => {
    balance += clickPower;
    updateDisplay();
});

// Система пассивного дохода
function updatePassiveIncome() {
    const now = Date.now();
    const duration = (now - lastUpdate) / 1000; // Время в секундах
    balance += duration * passiveIncome;
    lastUpdate = now;
    updateDisplay();
}

// Запускаем таймер для пассивного дохода (раз в секунду)
setInterval(updatePassiveIncome, 1000);

// Инициализация
updateDisplay();

