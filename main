import asyncio
import time
from aiogram import Bot, Dispatcher, types, F
from aiogram.filters import Command
from aiogram.utils.keyboard import ReplyKeyboardBuilder, InlineKeyboardBuilder

# Вставь сюда свой токен
TOKEN = "ТВОЙ_ТОКЕН_ОТ_BOTFATHER"

bot = Bot(token=TOKEN)
dp = Dispatcher()

# Имитация базы данных
users = {}

def get_user_data(user_id):
    if user_id not in users:
        users[user_id] = {
            "balance": 0,
            "click_power": 1,
            "passive_income": 0, # в секунду
            "last_update": time.time(),
            "level": 1,
            "quiz_passed": False
        }
    
    # Считаем пассивный доход перед возвратом данных
    now = time.time()
    duration = now - users[user_id]["last_update"]
    earned = duration * users[user_id]["passive_income"]
    users[user_id]["balance"] += earned
    users[user_id]["last_update"] = now
    
    return users[user_id]

# Главное меню
def main_menu_kb():
    builder = ReplyKeyboardBuilder()
    builder.button(text="🐹 Клик!")
    builder.button(text="📈 Магазин")
    builder.button(text="🎓 Профиль/Уровни")
    builder.adjust(1, 2)
    return builder.as_markup(resize_keyboard=True)

@dp.message(Command("start"))
async def start(message: types.Message):
    get_user_data(message.from_user.id)
    await message.answer(
        "Добро пожаловать в Fintech-хомяк! 🐹\nКликая, ты учишься управлять капиталом.",
        reply_markup=main_menu_kb()
    )

# Логика клика
@dp.message(F.text == "🐹 Клик!")
async def tap(message: types.Message):
    user = get_user_data(message.from_user.id)
    user["balance"] += user["click_power"]
    await message.answer(f"Ты заработал {user['click_power']} 🪙! Баланс: {int(user['balance'])}")

# Магазин карточек
@dp.message(F.text == "📈 Магазин")
async def shop(message: types.Message):
    builder = InlineKeyboardBuilder()
    # Карточка 1
    builder.button(text="💳 Дебетовая карта (+1/сек) - 50 🪙", callback_data="buy_card1")
    # Карточка 2
    builder.button(text="🚀 Криптобиржа (+10/сек) - 500 🪙", callback_data="buy_card2")
    builder.adjust(1)
    
    await message.answer("Выбери инвестицию:", reply_markup=builder.as_markup())

@dp.callback_query(F.data.startswith("buy_"))
async def buy_card(callback: types.CallbackQuery):
    user = get_user_data(callback.from_user.id)
    
    if callback.data == "buy_card1" and user["balance"] >= 50:
        user["balance"] -= 50
        user["passive_income"] += 1

import 'package:flutter/material.dart';
import 'package:provider/provider.dart';
import '../providers/game_provider.dart';
import '../models/quiz.dart';

class AcademyScreen extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    final provider = Provider.of<GameProvider>(context);
    final quizzes = provider.getAvailableQuizzes();

    return Scaffold(
      appBar: AppBar(title: Text('Финансовая академия'), backgroundColor: Colors.amber),
      body: quizzes.isEmpty
          ? Center(child: Text('Все викторины пройдены!\nПовышайте уровень для новых', textAlign: TextAlign.center))
          : ListView.builder(
              itemCount: quizzes.length,
              itemBuilder: (ctx, i) {
                final q = quizzes[i];
                return Card(
                  margin: EdgeInsets.all(12),
                  child: ListTile(
                    title: Text(q.question, style: TextStyle(fontWeight: FontWeight.bold)),
                    subtitle: Text('Награда: ${q.reward} ₿'),
                    trailing: Icon(Icons.quiz),
                    onTap: () => _showQuizDialog(context, q),
                  ),
                );
              },
            ),
    );
  }

  void _showQuizDialog(BuildContext context, QuizQuestion quiz) {
    final provider = Provider.of<GameProvider>(context, listen: false);
    showDialog(
      context: context,
      builder: (dialogCtx) {
        int selected = -1;
        return StatefulBuilder(
          builder: (ctx, setState) {
            return AlertDialog(
              title: Text(quiz.question),
              content: Column(
                mainAxisSize: MainAxisSize.min,
                children: List.generate(quiz.options.length, (idx) {
                  return RadioListTile<int>(
                    title: Text(quiz.options[idx]),
                    value: idx,
                    groupValue: selected,
                    onChanged: (val) => setState(() => selected = val!),
                  );
                }),
              ),
              actions: [
                TextButton(onPressed: () => Navigator.pop(ctx), child: Text('Отмена')),
                ElevatedButton(
                  onPressed: selected != -1
                      ? () {
                          final success = provider.answerQuiz(quiz, selected);
                          Navigator.pop(ctx);
                          ScaffoldMessenger.of(context).showSnackBar(
                            SnackBar(content: Text(success ? 'Правильно! +${quiz.reward} ₿' : 'Неверно, попробуй ещё раз')),
                          );
                        }
                      : null,
                  child: Text('Ответить'),
                ),
              ],
            );
          },
        );
      },
    );
  }
} import 'package:flutter/material.dart';
import '../models/card.dart';

class CardWidget extends StatelessWidget {
  final CardItem card;
  final bool isOwned;
  final VoidCallback onBuy;

  const CardWidget({super.key, required this.card, required this.isOwned, required this.onBuy});

  @override
  Widget build(BuildContext context) {
    return Card(
      margin: EdgeInsets.symmetric(vertical: 8),
      elevation: 3,
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(20)),
      child: Padding(
        padding: EdgeInsets.all(16),
        child: Row(
          children: [
            Expanded(
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Text(card.title, style: TextStyle(fontSize: 18, fontWeight: FontWeight.bold)),
                  SizedBox(height: 4),
                  Text(card.description, style: TextStyle(color: Colors.grey[600])),
                  SizedBox(height: 8),

Row(
                    children: [
                      Icon(Icons.monetization_on, size: 16, color: Colors.green),
                      Text(' ${card.incomeBoost} ₿/час', style: TextStyle(fontWeight: FontWeight.bold)),
                      SizedBox(width: 16),
                      if (card.riskFactor > 0)
                        Row(
                          children: [
                            Icon(Icons.warning_amber, size: 16, color: Colors.red),
                            Text(' Риск ${(card.riskFactor * 100).toInt()}%'),
                          ],
                        ),
                    ],
                  ),
                  if (card.isDebuffed)
                    Padding(
                      padding: EdgeInsets.only(top: 4),
                      child: Text('⚠️ Временно заблокирована риском', style: TextStyle(color: Colors.red, fontSize: 12)),
                    ),
                ],
              ),
            ),
            if (!isOwned)
              ElevatedButton(
                onPressed: onBuy,
                style: ElevatedButton.styleFrom(backgroundColor: Colors.amber),
                child: Text('${card.price} ₿'),
              )
            else
              Chip(label: Text('Приобретено'), backgroundColor: Colors.grey.shade300),
          ],
        ),
      ),
    );
  }
}
